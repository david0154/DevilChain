# DevilChain Docker Environment
# Copy this to .env and edit as needed

# Node
DEVIL_MODE=testnet
DEVIL_BLOCK_TIME=3
DEVIL_MAX_TX_POOL=500
RUST_LOG=warn

# Ports
NODE_PORT=8545
GRAPHQL_PORT=8546
AI_PORT=8547
STORAGE_PORT=8548
BRIDGE_PORT=8549
EXPLORER_PORT=3000
SOCIAL_PORT=3001
CHAT_PORT=3002

# Next.js
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_API_URL=http://localhost:8545

# Redis
REDIS_MAXMEMORY=24mb

# Miner (optional)
MINER_THREADS=1
MINER_ADDR=db1xmining_pool
