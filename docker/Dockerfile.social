# DevilSocial - Next.js
FROM node:20-alpine AS builder
WORKDIR /app
COPY social/package.json ./
RUN npm install
COPY social/ ./
RUN npm run build

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production PORT=3001
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
EXPOSE 3001
CMD ["node", "server.js"]
