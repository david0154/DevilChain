# DevilChat - Next.js
FROM node:20-alpine AS builder
WORKDIR /app
COPY chat/package.json ./
RUN npm install
COPY chat/ ./
RUN npm run build

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production PORT=3002
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
EXPOSE 3002
CMD ["node", "server.js"]
